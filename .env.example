# Required for scraping Google Maps reviews (Outscraper API)
# Get your key: https://app.outscraper.com/profile
OUTSCRAPER_API_KEY=your_outscraper_key_here

# Required for theme extraction and summary (Hugging Face Inference API)
# Get your token: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Required for the web app (async job queue). Default works with local Redis.
REDIS_URL=redis://localhost:6379/0

# Optional: override defaults
# OUTPUT_DIR=./output
# DATABASE_PATH=./data/app.db
# REVIEWS_LIMIT=200

# Database: default is SQLite at DATABASE_PATH. For production PostgreSQL, set:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# RQ job timeout (seconds) and retries (exponential backoff)
# RQ_JOB_TIMEOUT=300
# RQ_RETRY_MAX=3
# RQ_RETRY_INTERVALS=60,120,300
